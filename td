  <script>
    function buscarStatusProtocolo() {
      const input = document.getElementById("protocoloInput");
      const numero = input.value.trim();

      if (numero === "") {
        exibirModalStatus("⚠️ Por favor, informe um número de protocolo válido para efectuar a varredura.", "alert");
        return;
      }

      exibirModalStatus("🔄 Conectando ao servidor de arquivos do Google... Aguarde.", "loading");

      const urlAcessoScript = "https://script.google.com/macros/s/AKfycby-nSfjya6gEiNUhpU3mZEULKLPcU-i4zGXSAvabcyDZRoOkX9X5iuciA_bx-LXp5ov/exec";

      fetch(`${urlAcessoScript}?protocolo=${numero}`)
        .then(response => {
          if (!response.ok) throw new Error("Erro de resposta na rede HTTP.");
          return response.text(); 
        })
        .then(textoPuro => {
          try {
            const data = JSON.parse(textoPuro);
            const statusClean = data.status ? data.status.trim().toLowerCase() : "";

            if (statusClean === "nao_pago" || statusClean.includes("pagamento")) {
              exibirModalStatus(`Protocolo ${numero}:<br><span class="font-bold text-red-600 text-lg block mt-1">Situação: Aguardando Pagamento de Custas.</span>`, "alert");
            } else if (statusClean === "analise" || statusClean.includes("em analise")) {
              exibirModalStatus(`Protocolo ${numero}:<br><span class="font-bold text-blue-600 text-lg block mt-1">Situação: Em análise.</span>`, "info");
            } else if (statusClean === "nota" || statusClean.includes("devolutiva")) {
              exibirModalStatus(`Protocolo ${numero}:<br><span class="font-bold text-amber-600 text-lg block mt-1">Situação: Aguardando cumprimento de Nota Devolutiva.</span>`, "warning");
            } else if (statusClean === "usucapiao" || statusClean.includes("andamento")) {
              exibirModalStatus(`Protocolo ${numero}:<br><span class="font-bold text-indigo-600 text-lg block mt-1">Situação: Procedimento em andamento.</span>`, "process");
            } else if (statusClean === "finalizado") {
              exibirModalStatus(`Protocolo ${numero}:<br><span class="font-bold text-emerald-600 text-lg block mt-1">Situação: Finalizado.</span>`, "success");
            } else if (statusClean === "nao_localizado" || statusClean.includes("localizado")) {
              exibirModalStatus(`Protocolo ${numero}:<br><span class="font-bold text-red-500 text-lg block mt-1">Protocolo não localizado.</span><br><span class="text-xs text-slate-500 mt-2 block font-normal">Entre em contato com o cartório.</span>`, "alert");
            } else if (statusClean === "erro") {
              exibirModalStatus(`❌ Erro no Google Script:<br><span class="text-sm text-red-500 block mt-1 font-normal">${data.msg || "Erro desconhecido."}</span>`, "alert");
            } else {
              exibirModalStatus(`Protocolo ${numero}:<br><span class="font-bold text-slate-800 text-lg block mt-1">Situação: ${data.status}</span>`, "info");
            }
          } catch(err) {
            if (textoPuro.includes("script-error") || textoPuro.includes("Authorization")) {
              exibirModalStatus("❌ Erro de Autorização/Permissão no Google.<br><span class='text-xs text-slate-500 font-normal block mt-2 leading-relaxed text-left bg-slate-50 p-2 rounded border border-slate-200'>Certifique-se de que a implantação do Apps Script foi configurada com acesso para 'Qualquer pessoa' (Anyone) e que a conta do cartório autorizou a execução do código de varredura.</span>", "alert");
            } else {
              exibirModalStatus("❌ Erro de Sintaxe de Código Interno no Script.<br><span class='text-xs text-slate-500 font-normal block mt-2 leading-relaxed text-left bg-slate-50 p-2 rounded border border-slate-200'>O Google Script tentou varrer as pastas mas travou por erro de digitação interno ou ID de pasta inválido. Verifique o arquivo do Apps Script.</span>", "alert");
            }
          }
        })
        .catch(error => {
          console.error("Erro na busca nominal:", error);
          exibirModalStatus("❌ Falha crítica de comunicação na rede. Verifique a URL do Apps Script.", "alert");
        });
    }

    function exibirModalStatus(mensagem, tipo) {
      const modal = document.getElementById("protocoloModal");
      const msgCorpo = document.getElementById("modalMensagem");
      const iconBox = document.getElementById("modalIconContainer");
      
      msgCorpo.innerHTML = mensagem;
      
      if (tipo === "alert") {
        iconBox.className = "w-16 h-16 mx-auto rounded-full flex items-center justify-center mb-4 bg-red-50 text-red-500";
        iconBox.innerHTML = '<svg class="w-8 h-8 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>';
      } else if (tipo === "loading") {
        iconBox.className = "w-16 h-16 mx-auto rounded-full flex items-center justify-center mb-4 bg-slate-100 text-slate-500";
        iconBox.innerHTML = '<svg class="w-8 h-8 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 8H17"></path></svg>';
      } else if (tipo === "info") {
        iconBox.className = "w-16 h-16 mx-auto rounded-full flex items-center justify-center mb-4 bg-blue-50 text-blue-500";
        iconBox.innerHTML = '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>';
      } else if (tipo === "warning") {
        iconBox.className = "w-16 h-16 mx-auto rounded-full flex items-center justify-center mb-4 bg-amber-50 text-amber-500";
        iconBox.innerHTML = '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>';
      } else if (tipo === "process") {
        iconBox.className = "w-16 h-16 mx-auto rounded-full flex items-center justify-center mb-4 bg-indigo-50 text-indigo-500";
        iconBox.innerHTML = '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>';
      } else {
        iconBox.className = "w-16 h-16 mx-auto rounded-full flex items-center justify-center mb-4 bg-emerald-50 text-emerald-500";
        iconBox.innerHTML = '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>';
      }

      modal.classList.remove("hidden");
      modal.classList.add("flex");
    }

    function fecharProtocoloModal() {
      const modal = document.getElementById("protocoloModal");
      modal.classList.remove("shadow-2xl", "flex");
      modal.classList.add("hidden");
    }

    document.addEventListener("DOMContentLoaded", function() {
      const consentBanner = document.getElementById("cookieConsent");
      const acceptBtn = document.getElementById("acceptCookies");

      if (!localStorage.getItem("cookiesAccepted")) {
        consentBanner.classList.remove("hidden");
      }

      acceptBtn.addEventListener("click", function() {
        localStorage.setItem("cookiesAccepted", "true");
        consentBanner.classList.add("hidden");
      });

      // Nota: Caso reintroduza o elemento input com id 'protocoloInput' no HTML, o listener abaixo interceptará o Enter perfeitamente.
      const pInput = document.getElementById("protocoloInput");
      if (pInput) {
        pInput.addEventListener("keypress", function(e) {
          if (e.key === "Enter") {
            buscarStatusProtocolo();
          }
        });
      }
    });
  </script>
